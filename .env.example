# Telegram
BOT_TOKEN=123456:ABC
GROUP_ID=-1001234567890           # супергруппа с включёнными темами (форум)
MOD_TOPIC_ID=                     # message_thread_id служебной темы для премодерации (необязательно)
OWNER_ID=123456789                # ваш Telegram user_id — единственный владелец

# Pollinations
POLLINATIONS_API_KEY=sk_...
AI_MAIN_MODEL=gemini-fast
AI_EMBED_MODEL=openai-3-small
AI_EMBED_DIMS=512

# Pipeline
FETCH_INTERVAL_MIN=15
QA_RATE_PER_HOUR=10
SIMILARITY_THRESHOLD=0.82

# Auto-update
GIT_AUTO_UPDATE=true
GIT_CHECK_INTERVAL_MIN=10
GIT_BRANCH=main
